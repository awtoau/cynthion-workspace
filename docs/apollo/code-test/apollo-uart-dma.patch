+	// for error-flag handling (BUFOVF/FERR/PERR) in SERCOM2_Handler.
 	sercom->USART.INTENSET.reg = SERCOM_USART_INTENSET_RXC;
 
 	// Enable the UART IRQ.
@@ -143,6 +146,10 @@ void uart_initialize(bool configure_pinmux, unsigned long baudrate)
 	sercom->USART.CTRLA.bit.ENABLE = 1;
 	while(sercom->USART.SYNCBUSY.bit.ENABLE);
 
