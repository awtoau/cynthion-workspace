 // Switching the shared USB port to the FPGA is allowed.
 static bool fpga_usb_allowed = false;
 
-// Duration of the time window (in milliseconds).
-#define WINDOW_PERIOD_MS 200UL
+// UART heartbeat is considered valid for this many milliseconds.
+#define HEARTBEAT_VALID_MS 300UL
 
-// Store the timestamp of the last time window update.
-static uint32_t last_update = 0;
+// Sideband UART framing test pattern.
+static const uint8_t sideband_pattern[4] = { 0xC1, 0x14, 0x01, 0xA5 };
 
-// Counter of edges detected within the last time window.
-static uint32_t window_edges = 0;
+// We use SERCOM1 on PA09 (function C, PAD3 RX).
+static Sercom *fpga_adv_sercom = SERCOM1;
 
-// Counter of edges detected since the last time window update.
-static volatile uint32_t edge_counter = 0;
+// Parser state and counters.
+static volatile uint32_t rx_bytes = 0;
+static volatile uint32_t good_patterns = 0;
+static volatile uint32_t framing_errors = 0;
+static volatile uint32_t overruns = 0;
+static volatile uint8_t pattern_index = 0;
+
+// Timestamp of the most recent validated pattern.
+static volatile uint32_t last_valid_pattern_ms = 0;
 
 #endif
 
@@ -43,35 +51,61 @@ static volatile uint32_t edge_counter = 0;
 void fpga_adv_init(void)
 {
 #ifdef BOARD_HAS_USB_SWITCH
-	// Enable the APB clock for EIC (External Interrupt Controller).
-	_pm_enable_bus_clock(PM_BUS_APBA, EIC);
-
-	// Configure GCLK for EIC.
-	_gclk_enable_channel(GCLK_CLKCTRL_ID_EIC_Val, GCLK_CLKCTRL_GEN_GCLK0_Val);
-	while (GCLK->STATUS.bit.SYNCBUSY);
-
-	// Configure FPGA_ADV as an input with function A (external interrupt).
+	// Configure FPGA_ADV as input with function C (SERCOM1/PAD3 RX).
 	gpio_set_pin_direction(FPGA_ADV, GPIO_DIRECTION_IN);
 	gpio_set_pin_pull_mode(FPGA_ADV, GPIO_PULL_UP);
-	gpio_set_pin_function(FPGA_ADV, MUX_PA09A_EIC_EXTINT7);
-
-	// Disable EIC.
-	EIC->CTRL.bit.ENABLE = 0;
-	while (EIC->STATUS.bit.SYNCBUSY);
-
-	// Configure EIC to trigger on rising edge.
-	EIC->CONFIG[0].reg &= ~EIC_CONFIG_SENSE7_Msk;
-	EIC->CONFIG[0].reg |= EIC_CONFIG_SENSE7_RISE;
-
-	// Enable External Interrupt.
-	EIC->INTENSET.reg = EIC_INTENSET_EXTINT(1 << 7);
-
-	// Enable EIC.
-	EIC->CTRL.bit.ENABLE = 1;
-	while (EIC->STATUS.bit.SYNCBUSY);
-
-	// Enable IRQ.
-	NVIC_EnableIRQ(EIC_IRQn);
+	gpio_set_pin_function(FPGA_ADV, MUX_PA09C_SERCOM1_PAD3);
+
+	// Configure clocking for SERCOM1.
+	_pm_enable_bus_clock(PM_BUS_APBC, fpga_adv_sercom);
+	_gclk_enable_channel(SERCOM1_GCLK_ID_CORE, GCLK_CLKCTRL_GEN_GCLK0_Val);
+
+	while (fpga_adv_sercom->USART.SYNCBUSY.bit.ENABLE);
+	fpga_adv_sercom->USART.CTRLA.bit.ENABLE = 0;
+
+	while (fpga_adv_sercom->USART.SYNCBUSY.bit.SWRST);
+	fpga_adv_sercom->USART.CTRLA.bit.SWRST = 1;
+	while (fpga_adv_sercom->USART.SYNCBUSY.bit.SWRST);
+	while (fpga_adv_sercom->USART.SYNCBUSY.bit.SWRST || fpga_adv_sercom->USART.SYNCBUSY.bit.ENABLE);
+
+	// 8-N-1 receive at 1 Mbaud, LSB-first, internal clock.
+	fpga_adv_sercom->USART.CTRLA.reg =
+		SERCOM_USART_CTRLA_DORD            |
+		SERCOM_USART_CTRLA_RXPO(3)         |
+		SERCOM_USART_CTRLA_SAMPR(0)        |
+		SERCOM_USART_CTRLA_RUNSTDBY        |
+		SERCOM_USART_CTRLA_MODE_USART_INT_CLK;
+
+	// Same optimized BAUD calculation used by existing UART code.
+	const uint32_t baudrate = 1000000;
+	const uint32_t m1 =  (1ULL << 32) / CONF_CPU_FREQUENCY;
+	const uint32_t m2 = ((1ULL << 42) / CONF_CPU_FREQUENCY) & 0x3FF;
+	const uint32_t m3 = ((1ULL << 52) / CONF_CPU_FREQUENCY) & 0x3FF;
+	const uint32_t m4 = ((1ULL << 62) / CONF_CPU_FREQUENCY) & 0x3FF;
+	const uint32_t op4 = (baudrate * m4 -   1) >> 10;
+	const uint32_t op3 = (baudrate * m3 + op4) >> 10;
+	const uint32_t op2 = (baudrate * m2 + op3) >> 10;
+	const uint32_t op1 = (baudrate * m1 + op2) >> 12;
+	const uint32_t baud = 65535 - op1;
+	fpga_adv_sercom->USART.BAUD.reg = baud;
+
+	// Receive-only.
+	fpga_adv_sercom->USART.CTRLB.reg =
+		SERCOM_USART_CTRLB_CHSIZE(0) |
+		SERCOM_USART_CTRLB_RXEN;
+
+	while (fpga_adv_sercom->USART.SYNCBUSY.bit.CTRLB);
+
+	// Enable RX complete interrupt.
+	fpga_adv_sercom->USART.INTENSET.reg = SERCOM_USART_INTENSET_RXC;
+	NVIC_EnableIRQ(SERCOM1_IRQn);
+
+	fpga_adv_sercom->USART.CTRLA.bit.ENABLE = 1;
+	while (fpga_adv_sercom->USART.SYNCBUSY.bit.ENABLE);
+
+	last_valid_pattern_ms = 0;
+#else
+	// Boards without USB switch keep existing behavior and don't use FPGA_ADV UART.
 #endif
 }
 
