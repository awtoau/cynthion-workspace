 			return handle_jtag_stop(rhport, request);
 		case VENDOR_REQUEST_JTAG_GET_STATE:
 			return handle_jtag_get_state(rhport, request);
 
+		case VENDOR_REQUEST_EMERGENCY_RESET:
+			return handle_emergency_reset(rhport, request);
