 void fpga_adv_task(void)
 {
 #ifdef BOARD_HAS_USB_SWITCH
-	// Wait for the defined time window.
-	if (board_millis() - last_update < WINDOW_PERIOD_MS) return;
-
-	// Update edge counts inside time window.
-	window_edges = edge_counter;
-	edge_counter = 0;
-	last_update  = board_millis();
-
-    // Take over USB if the FPGA is not requesting the port.
+	// Take over USB if the FPGA is not sending valid sideband telemetry.
 	if (fpga_requesting_port() == false) {
 		take_over_usb();
 	} else if (fpga_usb_allowed) {
@@ -121,8 +147,8 @@ void allow_fpga_takeover_usb(bool allow)
 bool fpga_requesting_port(void)
 {
 #ifdef BOARD_HAS_USB_SWITCH
-	// True iff the number of edge counts surpasses the defined threshold.
-	return window_edges > 2;
+	uint32_t now = board_millis();
+	return (now - last_valid_pattern_ms) <= HEARTBEAT_VALID_MS;
 #else
 	return false;
 #endif
@@ -131,13 +157,36 @@ bool fpga_requesting_port(void)
 
 #ifdef BOARD_HAS_USB_SWITCH
 /**
- * FPGA_ADV interrupt handler.
+ * SERCOM1 interrupt handler for FPGA_ADV UART RX.
  */
-void EIC_Handler(void) {
-  // Clear the interrupt flag.
-  EIC->INTFLAG.reg = EIC_INTFLAG_EXTINT(1 << 7);
-
-  // Increment our edge counter.
-  edge_counter++;
+void SERCOM1_Handler(void) {
+	if (fpga_adv_sercom->USART.INTFLAG.bit.RXC) {
+		uint16_t status = fpga_adv_sercom->USART.STATUS.reg;
+
+		if (status & SERCOM_USART_STATUS_FERR) {
+			framing_errors++;
+		}
+		if (status & SERCOM_USART_STATUS_BUFOVF) {
+			overruns++;
+		}
+
+		if (status & (SERCOM_USART_STATUS_FERR | SERCOM_USART_STATUS_BUFOVF | SERCOM_USART_STATUS_PERR)) {
+			fpga_adv_sercom->USART.STATUS.reg = status;
+		}
+
+		uint8_t byte = (uint8_t) fpga_adv_sercom->USART.DATA.reg;
+		rx_bytes++;
+
+		if (byte == sideband_pattern[pattern_index]) {
+			pattern_index++;
+			if (pattern_index == sizeof(sideband_pattern)) {
+				good_patterns++;
+				last_valid_pattern_ms = board_millis();
+				pattern_index = 0;
+			}
+		} else {
+			pattern_index = (byte == sideband_pattern[0]) ? 1 : 0;
+		}
+	}
 }
 #endif
diff --git a/firmware/src/console.c b/firmware/src/console.c
index 347c347..469c417 100644
--- a/firmware/src/console.c
