@@ -54,6 +54,7 @@ enum {
 	VENDOR_REQUEST_TRIGGER_RECONFIGURATION = 0xc0,
 	VENDOR_REQUEST_FORCE_FPGA_OFFLINE      = 0xc1,
 	VENDOR_REQUEST_ALLOW_FPGA_TAKEOVER_USB = 0xc2,
+	VENDOR_REQUEST_BOOT_TO_DFU             = 0xed,
 
 
